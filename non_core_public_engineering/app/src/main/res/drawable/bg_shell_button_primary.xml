<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape>
            <corners android:radius="28dp" />
            <solid android:color="#273849" />
        </shape>
    </item>
    <item>
        <shape>
            <corners android:radius="28dp" />
