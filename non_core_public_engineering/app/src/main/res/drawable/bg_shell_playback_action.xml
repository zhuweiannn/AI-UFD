<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape>
            <corners android:radius="18dp" />
            <solid android:color="#122031" />
            <stroke
                android:width="1dp"
                android:color="#23384B" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape>
            <corners android:radius="18dp" />
            <solid android:color="@color/shell_accent_soft" />
            <stroke
                android:width="1dp"
                android:color="@color/shell_accent" />
        </shape>
    </item>
    <item>
        <shape>
            <corners android:radius="18dp" />
            <solid android:color="@color/shell_bg_secondary" />
            <stroke
                android:width="1dp"
                android:color="@color/shell_card_border" />
        </shape>
    </item>
</selector>
