<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape>
            <corners android:radius="18dp" />
            <solid android:color="#24161A" />
            <stroke
                android:width="1dp"
                android:color="#5B3038" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape>
            <corners android:radius="18dp" />
            <solid android:color="#4A252C" />
            <stroke
                android:width="1dp"
                android:color="@color/shell_error" />
        </shape>
    </item>
    <item>
        <shape>
            <corners android:radius="18dp" />
            <solid android:color="#331C23" />
            <stroke
                android:width="1dp"
                android:color="#A85765" />
        </shape>
    </item>
</selector>
