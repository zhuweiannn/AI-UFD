<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape>
            <corners android:radius="28dp" />
            <solid android:color="#132031" />
            <stroke
                android:width="1dp"
                android:color="#2B455B" />
        </shape>
    </item>
    <item>
        <shape>
            <corners android:radius="28dp" />
            <gradient
                android:angle="0"
                android:endColor="#17314A"
                android:startColor="#102539" />
            <stroke
                android:width="1dp"
                android:color="@color/shell_accent" />
        </shape>
    </item>
</selector>
