<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".feature.camera.CameraCaptureFragment">

    <LinearLayout
        android:id="@+id/fragmentRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_shell_gradient"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/captureToolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_video_assistant_toolbar"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp">

            <ImageButton
                android:id="@+id/buttonBackCapture"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/back"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_back_24" />

            <TextView
                android:id="@+id/captureTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/camera_capture_title"
                android:textColor="@color/shell_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/buttonCaptureSettings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/settings"
                android:padding="8dp"
                android:src="@drawable/ic_settings_24" />
        </LinearLayout>

        <TextView
            android:id="@+id/textCaptureStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="18dp"
            android:paddingTop="12dp"
            android:paddingEnd="18dp"
            android:paddingBottom="12dp"
            android:textColor="@color/shell_text_secondary"
            android:textSize="14sp"
            tools:text="开启摄像头前可先查看最近录制的视频记录。" />

        <FrameLayout
            android:id="@+id/captureStageHost"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/entryStageContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingBottom="28dp"
                android:visibility="gone">

                <Button
                    android:id="@+id/buttonOpenCamera"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_video_assistant_button_primary"
                    android:text="@string/camera_open_preview"
                    android:textAllCaps="false"
                    android:textColor="@color/shell_text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textRecordedVideoSectionTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/camera_recorded_videos_title"
                    android:textColor="@color/shell_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textRecordedVideoEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_shell_card"
                    android:padding="18dp"
                    android:text="@string/camera_recorded_videos_empty"
                    android:textColor="@color/shell_text_secondary"
                    android:textSize="14sp"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recordedVideoList"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="12dp"
                    android:layout_weight="1"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="true"
                    android:overScrollMode="ifContentScrolls"
                    android:paddingBottom="8dp"
                    android:visibility="gone" />
            </LinearLayout>

            <androidx.core.widget.NestedScrollView
                android:id="@+id/contentScroll"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="28dp">

                    <LinearLayout
                        android:id="@+id/mediaCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_shell_card"
                        android:orientation="vertical">

                        <com.example.liquid_detect.feature.videoassistant.AspectRatioFrameLayout
                            android:id="@+id/cameraPreviewFrame"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@color/shell_bg">

                            <SurfaceView
                                android:id="@+id/cameraPreviewSurface"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent" />

                            <LinearLayout
                                android:id="@+id/cameraPreviewTransitionPlaceholder"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@color/shell_bg"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:paddingStart="28dp"
                                android:paddingEnd="28dp"
                                android:visibility="gone">

                                <View
                                    android:layout_width="96dp"
                                    android:layout_height="12dp"
                                    android:background="@drawable/bg_shell_surface_placeholder_line" />

                                <View
                                    android:layout_width="164dp"
                                    android:layout_height="12dp"
                                    android:layout_marginTop="12dp"
                                    android:background="@drawable/bg_shell_surface_placeholder_line" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="18dp"
                                    android:text="@string/camera_preview_transition_hint"
                                    android:textColor="@color/shell_text_secondary"
                                    android:textSize="14sp" />
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/cameraLoadingGroup"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:visibility="gone">

                                <ProgressBar
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:indeterminate="true" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="10dp"
                                    android:text="@string/camera_preview_loading"
                                    android:textColor="@color/shell_text_secondary"
                                    android:textSize="14sp" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/textCapturePreviewHint"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:gravity="center"
                                android:paddingStart="28dp"
                                android:paddingEnd="28dp"
                                android:text="@string/camera_capture_preview_hint"
                                android:textColor="@color/shell_text_secondary"
                                android:textSize="16sp" />
                        </com.example.liquid_detect.feature.videoassistant.AspectRatioFrameLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/shell_card_border" />

                        <LinearLayout
                            android:id="@+id/previewControlsCard"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_video_assistant_footer"
                            android:orientation="vertical"
                            android:paddingStart="14dp"
                            android:paddingTop="14dp"
                            android:paddingEnd="14dp"
                            android:paddingBottom="14dp"
                            android:visibility="gone">

                            <TextView
                                android:id="@+id/textPreviewControlsTitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/camera_preview_controls_title"
                                android:textColor="@color/shell_text_primary"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/textPreviewControlsSubtitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="@string/camera_preview_controls_subtitle"
                                android:textColor="@color/shell_text_secondary"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/textCaptureProfileLabel"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="14dp"
                                android:text="@string/camera_resolution"
                                android:textColor="@color/shell_text_secondary"
                                android:textSize="13sp" />

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/inputLayoutCaptureResolution"
                                style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                app:boxBackgroundColor="@color/shell_bg_secondary"
                                app:boxStrokeColor="@color/shell_accent"
                                app:endIconContentDescription="@string/camera_profile_popup_title"
                                app:endIconDrawable="@drawable/ic_arrow_drop_down_24"
                                app:endIconMode="custom"
                                app:hintEnabled="false">

                                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                                    android:id="@+id/dropdownCaptureResolution"
                                    android:layout_width="match_parent"
                                    android:layout_height="56dp"
                                    android:clickable="true"
                                    android:cursorVisible="false"
                                    android:ellipsize="end"
                                    android:focusable="false"
                                    android:focusableInTouchMode="false"
                                    android:importantForAutofill="no"
                                    android:gravity="center_vertical"
                                    android:inputType="none"
                                    android:maxLines="1"
                                    android:paddingStart="18dp"
                                    android:paddingTop="0dp"
                                    android:paddingEnd="18dp"
                                    android:paddingBottom="0dp"
                                    android:textColor="@color/shell_text_primary"
                                    android:textColorHint="@color/shell_text_secondary" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="14dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <ImageButton
                                    android:id="@+id/buttonSwitchCamera"
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:background="@drawable/bg_shell_playback_action"
                                    android:contentDescription="@string/camera_facing_back"
                                    android:padding="8dp"
                                    android:src="@drawable/ic_camera_rear_24"
                                    android:tint="@color/shell_text_primary" />

                                <TextView
                                    android:id="@+id/textPreviewDemoLabel"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="12dp"
                                    android:layout_weight="1"
                                    android:text="@string/camera_preview_demo"
                                    android:textColor="@color/shell_text_primary"
                                    android:textSize="14sp" />

                                <androidx.appcompat.widget.SwitchCompat
                                    android:id="@+id/switchPreviewDemo"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" />
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/recordingControlsCard"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_video_assistant_footer"
                            android:orientation="vertical"
                            android:paddingStart="14dp"
                            android:paddingTop="14dp"
                            android:paddingEnd="14dp"
                            android:paddingBottom="14dp"
                            android:visibility="gone">

                            <TextView
                                android:id="@+id/textRecordingTitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/camera_recording_title"
                                android:textColor="@color/shell_text_primary"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/textRecordingSubtitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="@string/camera_recording_subtitle"
                                android:textColor="@color/shell_text_secondary"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/textRecordingFileName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:textColor="@color/shell_text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                tools:text="VID_20260409_205900.mp4" />

                            <TextView
                                android:id="@+id/textRecordingMeta"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:textColor="@color/shell_text_secondary"
                                android:textSize="13sp"
                                tools:text="已录制 00:12 · 1024×738" />

                        </LinearLayout>
                    </LinearLayout>

                    <Button
                        android:id="@+id/buttonStartRecording"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_video_assistant_button_primary"
                        android:text="@string/camera_start_recording"
                        android:textAllCaps="false"
                        android:textColor="@color/shell_text_primary"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <Button
                        android:id="@+id/buttonStopRecording"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_video_assistant_button_warning"
                        android:text="@string/camera_stop_recording"
                        android:textAllCaps="false"
                        android:textColor="@color/shell_text_primary"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </FrameLayout>
    </LinearLayout>
</FrameLayout>
