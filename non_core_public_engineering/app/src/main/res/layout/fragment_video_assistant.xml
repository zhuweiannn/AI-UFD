<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".feature.videoassistant.VideoAssistantFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_shell_gradient"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/videoAssistantToolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_video_assistant_toolbar"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp">

            <ImageButton
                android:id="@+id/buttonBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/back"
                android:src="@drawable/ic_arrow_back_24" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/video_assistant_title"
                android:textColor="@color/shell_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/buttonSettings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/settings"
                android:src="@drawable/ic_settings_24" />
        </LinearLayout>

        <TextView
            android:id="@+id/textStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="18dp"
            android:paddingTop="12dp"
            android:paddingEnd="18dp"
            android:paddingBottom="12dp"
            android:textColor="@color/shell_text_secondary"
            android:textSize="14sp"
            tools:text="选择视频" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/chooseStageContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingBottom="28dp"
                android:visibility="gone">

                <Button
                    android:id="@+id/buttonChooseVideo"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_video_assistant_button_primary"
                    android:text="@string/choose_video"
                    android:textAllCaps="false"
                    android:textColor="@color/shell_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textHistorySectionTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/history_section_title"
                    android:textColor="@color/shell_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/historyList"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="12dp"
                    android:layout_weight="1"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="true"
                    android:overScrollMode="ifContentScrolls"
                    android:paddingBottom="8dp"
                    android:visibility="gone" />
            </LinearLayout>

            <androidx.core.widget.NestedScrollView
                android:id="@+id/contentScroll"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="28dp">

                <LinearLayout
                    android:id="@+id/mediaCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_shell_card"
                    android:orientation="vertical">

                    <com.example.liquid_detect.feature.videoassistant.AspectRatioFrameLayout
                        android:id="@+id/previewCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/shell_bg">

                        <SurfaceView
                            android:id="@+id/processingSurface"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:visibility="gone" />

                        <androidx.media3.ui.PlayerView
                            android:id="@+id/playerView"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:keepScreenOn="true"
                            app:surface_type="texture_view"
                            app:use_controller="false" />

                        <com.example.liquid_detect.replay.ReplayOverlayView
                            android:id="@+id/replayOverlay"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:visibility="gone" />

                        <LinearLayout
                            android:id="@+id/mediaLoadingGroup"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <ProgressBar
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:indeterminate="true" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="@string/video_preview_loading"
                                android:textColor="@color/shell_text_secondary"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/textPreviewHint"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:paddingStart="28dp"
                            android:paddingEnd="28dp"
                            android:text="@string/video_preview_hint"
                            android:textColor="@color/shell_text_secondary"
                            android:textSize="16sp" />
                    </com.example.liquid_detect.feature.videoassistant.AspectRatioFrameLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/shell_card_border" />

                    <LinearLayout
                        android:id="@+id/playbackControls"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_video_assistant_footer"
                        android:orientation="vertical"
                        android:paddingStart="14dp"
                        android:paddingTop="12dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="14dp">

                        <com.example.liquid_detect.media.playback.ShellPlaybackSeekBar
                            android:id="@+id/seekPlayback"
                            android:layout_width="match_parent"
                            android:layout_height="28dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageButton
                                android:id="@+id/buttonPlaybackToggle"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/bg_shell_playback_action"
                                android:contentDescription="@string/play_pause"
                                android:padding="8dp"
                                android:scaleType="centerInside"
                                android:src="@drawable/ic_play_24" />

                            <ImageButton
                                android:id="@+id/buttonPlaybackStop"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/bg_shell_playback_action"
                                android:contentDescription="@string/stop_playback"
                                android:layout_marginStart="8dp"
                                android:padding="8dp"
                                android:scaleType="centerInside"
                                android:src="@drawable/ic_stop_24" />

                            <ImageButton
                                android:id="@+id/buttonPlaybackMute"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/bg_shell_playback_action"
                                android:contentDescription="@string/mute_playback"
                                android:layout_marginStart="8dp"
                                android:padding="8dp"
                                android:scaleType="centerInside"
                                android:src="@drawable/ic_volume_up_24"
                                android:tint="@color/shell_text_primary" />

                            <ImageButton
                                android:id="@+id/buttonPlaybackFullscreen"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/bg_shell_playback_action"
                                android:contentDescription="@string/enter_fullscreen"
                                android:layout_marginStart="8dp"
                                android:padding="8dp"
                                android:scaleType="centerInside"
                                android:src="@drawable/ic_fullscreen_24"
                                android:tint="@color/shell_text_primary" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="1dp"
                                android:layout_weight="1" />

                            <TextView
                                android:id="@+id/textPlaybackTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="00:00/00:00"
                                android:textColor="@color/shell_text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/processingCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_video_assistant_footer"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ProgressBar
                                android:id="@+id/progressProcessing"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="0dp"
                                android:layout_height="16dp"
                                android:layout_weight="1"
                                android:max="1000"
                                android:progress="0"
                                android:progressDrawable="@drawable/bg_shell_progress" />

                            <TextView
                                android:id="@+id/textProgressPercent"
                                android:layout_width="52dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:gravity="end|center_vertical"
                                android:textColor="@color/shell_text_primary"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                tools:text="100%" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/textProgressFrames"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:textColor="@color/shell_text_primary"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                tools:text="1432/5848" />

                            <TextView
                                android:id="@+id/textProgressEta"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/shell_text_secondary"
                                android:textSize="13sp"
                                tools:text="预计剩余 01:30" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageButton
                                android:id="@+id/buttonProcessingToggleInline"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_shell_playback_action"
                                android:contentDescription="@string/pause_processing"
                                android:padding="8dp"
                                android:scaleType="centerInside"
                                android:src="@drawable/ic_pause_24" />

                            <ImageButton
                                android:id="@+id/buttonProcessingCancelInline"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_shell_processing_action_warning"
                                android:contentDescription="@string/cancel_processing"
                                android:padding="8dp"
                                android:scaleType="centerInside"
                                android:src="@drawable/ic_stop_24" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="1dp"
                                android:layout_weight="1" />

                            <ImageButton
                                android:id="@+id/buttonProcessingFullscreen"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_shell_playback_action"
                                android:contentDescription="@string/enter_fullscreen"
                                android:padding="8dp"
                                android:scaleType="centerInside"
                                android:src="@drawable/ic_fullscreen_24"
                                android:tint="@color/shell_text_primary" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <Button
                    android:id="@+id/buttonPrimaryAction"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_video_assistant_button_primary"
                    android:text="@string/start_processing"
                    android:textAllCaps="false"
                    android:textColor="@color/shell_text_primary"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/buttonCancelProcessing"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_video_assistant_button_warning"
                    android:text="@string/cancel_processing"
                    android:textAllCaps="false"
                    android:textColor="@color/shell_text_primary"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/recoveryCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_shell_card"
                    android:orientation="vertical"
                    android:padding="18dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/textRecoveryTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/recovery_title"
                        android:textColor="@color/shell_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textRecoverySubtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/shell_text_secondary"
                        android:textSize="14sp"
                        tools:text="检测到上次处理中断，可从最近进度继续。" />

                    <ProgressBar
                        android:id="@+id/progressRecovery"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="14dp"
                        android:layout_marginTop="14dp"
                        android:max="100"
                        android:progress="0"
                        android:progressDrawable="@drawable/bg_shell_progress" />

                    <TextView
                        android:id="@+id/textRecoveryPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/shell_text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        tools:text="65%" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/buttonRecoveryResume"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_video_assistant_button_primary"
                            android:text="@string/recovery_resume"
                            android:textAllCaps="false"
                            android:textColor="@color/shell_text_primary" />

                        <Button
                            android:id="@+id/buttonRecoveryDiscard"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_shell_button_secondary"
                            android:text="@string/recovery_discard"
                            android:textAllCaps="false"
                            android:textColor="@color/shell_text_primary" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/metadataCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_shell_card"
                    android:orientation="vertical"
                    android:padding="18dp">

                <TextView
                    android:id="@+id/textMetadataName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/shell_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="sample_video.mp4" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/metadata_size"
                        android:textColor="@color/shell_text_secondary" />

                    <TextView
                        android:id="@+id/textMetadataSize"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/shell_text_primary"
                        tools:text="124 MB" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/metadata_duration"
                        android:textColor="@color/shell_text_secondary" />

                    <TextView
                        android:id="@+id/textMetadataDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/shell_text_primary"
                        tools:text="03:15" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/metadata_resolution"
                        android:textColor="@color/shell_text_secondary" />

                    <TextView
                        android:id="@+id/textMetadataResolution"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/shell_text_primary"
                        tools:text="1920×1080" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/metadata_frames"
                        android:textColor="@color/shell_text_secondary" />

                    <TextView
                        android:id="@+id/textMetadataFrames"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/shell_text_primary"
                        tools:text="5848" />
                </LinearLayout>
            </LinearLayout>

                <TextView
                    android:id="@+id/textAnalysisWarning"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:textColor="@color/shell_warning"
                    android:textSize="14sp"
                    android:visibility="gone"
                    tools:text="分析结果暂不可用，可稍后重试分析。"
                    tools:visibility="visible" />

                <LinearLayout
                    android:id="@+id/resultSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_shell_card"
                    android:orientation="vertical"
                    android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/chart_levels_title"
                    android:textColor="@color/shell_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/chartLevels"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:layout_marginTop="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/chart_rates_title"
                    android:textColor="@color/shell_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/chartRates"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:layout_marginTop="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/result_summary"
                    android:textColor="@color/shell_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <GridLayout
                    android:id="@+id/gridSummaryTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:columnCount="2">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="项目名"
                        android:textColor="@color/shell_text_secondary" />

                    <TextView
                        android:id="@+id/projName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/shell_text_primary"
                        tools:text="sample_video.mp4" />
                </GridLayout>

                <GridLayout
                    android:id="@+id/gridSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:columnCount="3">

                    <TextView style="@style/SumLabel" android:text="最大尿流率" />
                    <TextView style="@style/SumValue" android:id="@+id/tvQmax" tools:text="15.2" />
                    <TextView style="@style/SumUnit" android:text="mL/s" />

                    <TextView style="@style/SumLabel" android:text="最大尿流率时间" />
                    <TextView style="@style/SumValue" android:id="@+id/tvTQmax" tools:text="12.5" />
                    <TextView style="@style/SumUnit" android:text="s" />

                    <TextView style="@style/SumLabel" android:text="平均尿流率" />
                    <TextView style="@style/SumValue" android:id="@+id/tvQavg" tools:text="9.8" />
                    <TextView style="@style/SumUnit" android:text="mL/s" />

                    <TextView style="@style/SumLabel" android:text="尿流时间" />
                    <TextView style="@style/SumValue" android:id="@+id/tvFtime" tools:text="21.0" />
                    <TextView style="@style/SumUnit" android:text="s" />

                    <TextView style="@style/SumLabel" android:text="排尿量" />
                    <TextView style="@style/SumValue" android:id="@+id/tvVol" tools:text="310" />
                    <TextView style="@style/SumUnit" android:text="mL" />

                    <TextView style="@style/SumLabel" android:text="排尿时间" />
                    <TextView style="@style/SumValue" android:id="@+id/tvVtime" tools:text="24.2" />
                    <TextView style="@style/SumUnit" android:text="s" />

                    <TextView style="@style/SumLabel" android:text="残余尿量" />
                    <TextView style="@style/SumValue" android:id="@+id/tvVdelta" tools:text="25" />
                    <TextView style="@style/SumUnit" android:text="mL" />
                </GridLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <FrameLayout
            android:id="@+id/fullscreenContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#E60A111C"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingTop="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="12dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">

                    <com.example.liquid_detect.feature.videoassistant.AspectRatioFrameLayout
                        android:id="@+id/fullscreenMediaFrame"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:background="@color/shell_bg">

                        <SurfaceView
                            android:id="@+id/fullscreenProcessingSurface"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:visibility="gone" />

                        <androidx.media3.ui.PlayerView
                            android:id="@+id/fullscreenPlayerView"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            app:surface_type="texture_view"
                            app:use_controller="false" />

                        <com.example.liquid_detect.replay.ReplayOverlayView
                            android:id="@+id/fullscreenReplayOverlay"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:visibility="gone" />

                        <LinearLayout
                            android:id="@+id/fullscreenMediaLoadingGroup"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <ProgressBar
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:indeterminate="true" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="@string/video_preview_loading"
                                android:textColor="@color/shell_text_secondary"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </com.example.liquid_detect.feature.videoassistant.AspectRatioFrameLayout>
                </FrameLayout>

                <LinearLayout
                    android:id="@+id/fullscreenPlaybackControls"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_shell_card"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.example.liquid_detect.media.playback.ShellPlaybackSeekBar
                        android:id="@+id/seekPlaybackFullscreen"
                        android:layout_width="match_parent"
                        android:layout_height="28dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageButton
                            android:id="@+id/buttonPlaybackToggleFullscreen"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_shell_playback_action"
                            android:contentDescription="@string/play_pause"
                            android:padding="8dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_play_24" />

                        <ImageButton
                            android:id="@+id/buttonPlaybackStopFullscreen"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_shell_playback_action"
                            android:contentDescription="@string/stop_playback"
                            android:padding="8dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_stop_24" />

                        <ImageButton
                            android:id="@+id/buttonPlaybackMuteFullscreen"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_shell_playback_action"
                            android:contentDescription="@string/mute_playback"
                            android:padding="8dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_volume_up_24"
                            android:tint="@color/shell_text_primary" />

                        <ImageButton
                            android:id="@+id/buttonPlaybackFullscreenFullscreen"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_shell_playback_action"
                            android:contentDescription="@string/exit_fullscreen"
                            android:padding="8dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_fullscreen_exit_24"
                            android:tint="@color/shell_text_primary" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/textPlaybackTimeFullscreen"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="00:00/00:00"
                            android:textColor="@color/shell_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/fullscreenProcessingControls"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_shell_card"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ProgressBar
                            android:id="@+id/progressProcessingFullscreen"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="0dp"
                            android:layout_height="16dp"
                            android:layout_weight="1"
                            android:max="1000"
                            android:progress="0"
                            android:progressDrawable="@drawable/bg_shell_progress" />

                        <TextView
                            android:id="@+id/textProgressPercentFullscreen"
                            android:layout_width="52dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:gravity="end|center_vertical"
                            android:textColor="@color/shell_text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            tools:text="100%" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/textProgressFramesFullscreen"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="@color/shell_text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            tools:text="1432/5848" />

                        <TextView
                            android:id="@+id/textProgressEtaFullscreen"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/shell_text_secondary"
                            android:textSize="13sp"
                            tools:text="预计剩余 01:30" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageButton
                            android:id="@+id/buttonProcessingToggleFullscreen"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_shell_playback_action"
                            android:contentDescription="@string/pause_processing"
                            android:padding="8dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_pause_24" />

                        <ImageButton
                            android:id="@+id/buttonProcessingCancelFullscreen"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_shell_processing_action_warning"
                            android:contentDescription="@string/cancel_processing"
                            android:padding="8dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_stop_24" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <ImageButton
                            android:id="@+id/buttonProcessingFullscreenFullscreen"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_shell_playback_action"
                            android:contentDescription="@string/exit_fullscreen"
                            android:padding="8dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_fullscreen_exit_24"
                            android:tint="@color/shell_text_primary" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>
        </FrameLayout>
    </LinearLayout>
</FrameLayout>
