<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="88dp"
    android:layout_marginTop="10dp"
    android:background="@drawable/bg_video_assistant_history_item">

    <View
        android:id="@+id/viewHistoryProgressFill"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:background="@drawable/bg_video_assistant_history_progress"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="14dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textHistoryTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/shell_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textHistoryBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:minHeight="24dp"
                    android:gravity="center"
                    android:paddingStart="10dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="4dp"
                    android:textColor="@color/shell_text_primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:id="@+id/textHistoryStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/shell_text_primary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/textHistoryDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/shell_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/buttonHistoryResume"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_shell_playback_action"
                android:contentDescription="@string/resume_processing"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_play_24"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/buttonHistoryCancel"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_shell_processing_action_warning"
                android:contentDescription="@string/cancel_processing"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_stop_24"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/buttonHistoryDelete"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_shell_processing_action_warning"
                android:contentDescription="@string/history_delete"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_delete_24"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
