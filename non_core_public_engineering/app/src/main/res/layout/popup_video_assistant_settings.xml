<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_shell_card"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings_title"
        android:textColor="@color/shell_text_primary"
        android:textSize="15sp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fadeScrollbars="false"
        android:fillViewport="true"
        android:overScrollMode="ifContentScrolls"
        android:scrollbarStyle="outsideInset"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingEnd="4dp">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/settings_model"
                app:boxBackgroundColor="@color/shell_bg_secondary"
                app:boxCollapsedPaddingTop="6dp"
                app:boxStrokeColor="@color/shell_accent"
                app:hintTextColor="@color/shell_text_secondary">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/dropdownModel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:dropDownWidth="match_parent"
                    android:ellipsize="end"
                    android:inputType="none"
                    android:maxLines="1"
                    android:minHeight="44dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:popupBackground="@drawable/bg_video_assistant_dropdown_menu"
                    android:textColor="@color/shell_text_primary"
                    android:textColorHint="@color/shell_text_secondary"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:hint="@string/settings_compute"
                app:boxBackgroundColor="@color/shell_bg_secondary"
                app:boxCollapsedPaddingTop="6dp"
                app:boxStrokeColor="@color/shell_accent"
                app:hintTextColor="@color/shell_text_secondary">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/dropdownCPUGPU"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:dropDownWidth="match_parent"
                    android:ellipsize="end"
                    android:inputType="none"
                    android:maxLines="1"
                    android:minHeight="44dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:popupBackground="@drawable/bg_video_assistant_dropdown_menu"
                    android:textColor="@color/shell_text_primary"
                    android:textColorHint="@color/shell_text_secondary"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:hint="@string/settings_segment_compute_protocol"
                app:boxBackgroundColor="@color/shell_bg_secondary"
                app:boxCollapsedPaddingTop="6dp"
                app:boxStrokeColor="@color/shell_accent"
                app:hintTextColor="@color/shell_text_secondary">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/dropdownSegmentComputeVersion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:dropDownWidth="match_parent"
                    android:ellipsize="end"
                    android:inputType="none"
                    android:maxLines="1"
                    android:minHeight="44dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:popupBackground="@drawable/bg_video_assistant_dropdown_menu"
                    android:textColor="@color/shell_text_primary"
                    android:textColorHint="@color/shell_text_secondary"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:hint="@string/settings_rotation"
                app:boxBackgroundColor="@color/shell_bg_secondary"
                app:boxCollapsedPaddingTop="6dp"
                app:boxStrokeColor="@color/shell_accent"
                app:hintTextColor="@color/shell_text_secondary">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/dropdownRotate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:dropDownWidth="match_parent"
                    android:ellipsize="end"
                    android:inputType="none"
                    android:maxLines="1"
                    android:minHeight="44dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:popupBackground="@drawable/bg_video_assistant_dropdown_menu"
                    android:textColor="@color/shell_text_primary"
                    android:textColorHint="@color/shell_text_secondary"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:minHeight="40dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:paddingEnd="12dp"
                    android:text="@string/settings_env"
                    android:textColor="@color/shell_text_secondary"
                    android:textSize="13sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchEnv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:minHeight="40dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:paddingEnd="12dp"
                    android:text="@string/settings_keep_screen_awake"
                    android:textColor="@color/shell_text_secondary"
                    android:textSize="13sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchKeepScreenAwake"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:minHeight="40dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:paddingEnd="12dp"
                    android:text="@string/settings_show_processing_notification"
                    android:textColor="@color/shell_text_secondary"
                    android:textSize="13sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchProcessingNotification"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:minHeight="40dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:paddingEnd="12dp"
                    android:text="@string/settings_show_live_processing_curves"
                    android:textColor="@color/shell_text_secondary"
                    android:textSize="13sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchLiveProcessingCurves"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <Button
                android:id="@+id/buttonManualFlush"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_video_assistant_button_primary"
                android:text="@string/settings_manual_flush"
                android:textAllCaps="false"
                android:textColor="@color/shell_text_primary"
                android:textSize="13sp" />

            <Button
                android:id="@+id/buttonReprocessVideo"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_shell_button_secondary"
                android:text="@string/settings_reprocess_video"
                android:textAllCaps="false"
                android:textColor="@color/shell_text_primary"
                android:textSize="13sp" />

            <Button
                android:id="@+id/buttonExportDebugBundle"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_shell_button_secondary"
                android:text="@string/settings_export_debug_bundle"
                android:textAllCaps="false"
                android:textColor="@color/shell_text_primary"
                android:textSize="13sp" />

            <Button
                android:id="@+id/buttonSnapshot"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_shell_button_secondary"
                android:text="@string/settings_snapshot"
                android:textAllCaps="false"
                android:textColor="@color/shell_text_primary"
                android:textSize="13sp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
